# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Assembly source
*.asm text eol=lf

# C source
*.c   text eol=lf
*.h   text eol=lf

# Build system
Makefile  text eol=lf
*.ld      text eol=lf

# Docs
*.md   text eol=lf
*.txt  text eol=lf

# Binary — never touch line endings
*.bin  binary
*.img  binary
*.o    binary
*.map  binary
